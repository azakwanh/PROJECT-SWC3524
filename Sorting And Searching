import java.util.*;

public class SortingAndSearching
{
    // Insertion Sort Algorithm
    public static String insertionSort(int[] arr)
    {
        int n = arr.length;
        int comparisons = 0;
        int swaps = 0;
        
        for (int i = 1; i < n; i++)
        {
            int key = arr[i];
            int j = i - 1;
            comparisons++;
            
            while (j >= 0 && arr[j] > key)
            {
                arr[j + 1] = arr[j];
                j--;
                swaps++;
                comparisons++;
            }
            arr[j + 1] = key;
        }
        
        return "Insertion Sort completed - Comparisons: " + comparisons + ", Swaps: " + swaps;
    }
    
    // Binary Search Algorithm (requires sorted array)
    public static String binarySearch(int[] arr, int target)
    {
        int left = 0;
        int right = arr.length - 1;
        int comparisons = 0;
        int position = -1;
        
        while (left <= right)
        {
            int mid = left + (right - left) / 2;
            comparisons++;
            
            if (arr[mid] == target)
            {
                position = mid;
                break;
            }
            else if (arr[mid] < target)
            {
                left = mid + 1;
            }
            else
            {
                right = mid - 1;
            }
        }
        
        if (position != -1)
        {
            return "Binary Search: " + target + " found at index " + position + 
                   " | Comparisons: " + comparisons;
        }
        else
        {
            return "Binary Search: " + target + " not found | Comparisons: " + comparisons;
        }
    }
    
    // Method to sort and search marketing costs
    public static String analyzeMarketingCosts(int[] costs, int targetCost)
    {
        System.out.println("Original Marketing Costs: " + Arrays.toString(costs));
        
        String sortResult = insertionSort(costs);
        System.out.println("Sorted Marketing Costs: " + Arrays.toString(costs));
        
        String searchResult = binarySearch(costs, targetCost);
        
        return sortResult + "\n" + searchResult;
    }
    
    // Method to find optimal route cost from cost matrix (for demonstration)
    public static int[] extractAllCosts(int[][] costMatrix)
    {
        List<Integer> costList = new ArrayList<>();
        for (int i = 0; i < costMatrix.length; i++)
        {
            for (int j = i + 1; j < costMatrix[i].length; j++)
            {
                if (costMatrix[i][j] > 0)
                {
                    costList.add(costMatrix[i][j]);
                }
            }
        }
        
        int[] costs = new int[costList.size()];
        for (int i = 0; i < costList.size(); i++)
        {
            costs[i] = costList.get(i);
        }
        return costs;
    }
    
    // Main method for testing
    public static void main(String[] args)
    {
        int[][] costMatrix = {
            {0, 15, 25, 35},
            {15, 0, 30, 28},
            {25, 30, 0, 20},
            {35, 28, 20, 0}
        };
        
        System.out.println("=== SORTING & SEARCHING DEMONSTRATION ===");
        System.out.println();
        
        // Example 1: Basic array sorting and searching
        int[] arr = {8, 3, 5, 1, 9, 2};
        System.out.println("Example 1 - Basic Array:");
        System.out.println("Original Array: " + Arrays.toString(arr));
        insertionSort(arr);
        System.out.println("Sorted Array: " + Arrays.toString(arr));
        System.out.println(binarySearch(arr, 5));
        System.out.println();
        
        // Example 2: Marketing costs analysis
        System.out.println("Example 2 - Marketing Costs Analysis:");
        int[] marketingCosts = extractAllCosts(costMatrix);
        System.out.println(analyzeMarketingCosts(marketingCosts, 25));
        System.out.println();
        
        // Example 3: Different target search
        System.out.println("Example 3 - Searching for different target:");
        int[] sortedArr = {1, 2, 3, 5, 8, 9};
        System.out.println("Sorted Array: " + Arrays.toString(sortedArr));
        System.out.println(binarySearch(sortedArr, 8));
        System.out.println(binarySearch(sortedArr, 10));
    }
}
